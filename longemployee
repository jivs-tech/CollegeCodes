// --- 4. ADD EMPLOYEE PAGE (Handling Data Entry & DatePicker) ---
class AddPage extends StatefulWidget {
  const AddPage({super.key});
  @override
  State<AddPage> createState() => _AddPageState();
}

class _AddPageState extends State<AddPage> {
  final idC = TextEditingController();
  final nameC = TextEditingController();
  final desC = TextEditingController();
  final salC = TextEditingController();
  String selectedDate = "Not Selected";

  // ASYNC Function: Used for the DatePicker because we must WAIT for user input.
  void _showDate() async {
    DateTime? picked = await showDatePicker(
      context: context,
      initialDate: DateTime.now(),
      firstDate: DateTime(2000), // Earliest year allowed
      lastDate: DateTime(2100), // Latest year allowed
    );
    // If user didn't cancel, update the selected date.
    if (picked != null) {
      setState(() {
        selectedDate = picked.toString().split(' ')[0]; // Formats to YYYY-MM-DD
      });
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text("New Employee Record")),
      body: ListView(
        padding: const EdgeInsets.all(20),
        children: [
          TextField(
              controller: idC, decoration: const InputDecoration(labelText: "ID")),
          TextField(
              controller: nameC,
              decoration: const InputDecoration(labelText: "Full Name")),
          TextField(
              controller: desC,
              decoration: const InputDecoration(labelText: "Designation")),
          TextField(
              controller: salC,
              decoration: const InputDecoration(labelText: "Basic Salary"),
              keyboardType: TextInputType.number), // Shows number keypad
          
          const SizedBox(height: 10),
          
          // Row for Date Selection
          Row(
            children: [
              Text("Join Date: $selectedDate"),
              IconButton(
                  onPressed: _showDate, icon: const Icon(Icons.calendar_today)),
            ],
          ),
          
          const SizedBox(height: 20),
          
          ElevatedButton(
              onPressed: () {
                // setState() tells Flutter to refresh the UI with new data.
                setState(() {
                  empList.add(Employee(
                      idC.text,
                      nameC.text,
                      desC.text,
                      double.parse(salC.text), // Converts String text to Double
                      selectedDate));
                });
                Navigator.pop(context); // Goes back to the previous screen
              },
              child: const Text("Save Employee Data")),
        ],
      ),
    );
  }
}

// --- 5. VIEW PAGE (Displaying Data in a List) ---
class ViewPage extends StatelessWidget {
  const ViewPage({super.key});
  
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text("Employee Registry")),
      // ListView.builder: Efficiently creates a list of items based on the data list.
      body: ListView.builder(
        itemCount: empList.length, // Total number of items in our global list
        itemBuilder: (c, i) => Card( // Card adds a nice shadow/border
          child: ListTile(
            leading: const Icon(Icons.person),
            title: Text(empList[i].name), // Accessing data by index 'i'
            subtitle: Text("ID: ${empList[i].id} | Joined: ${empList[i].date}"),
            trailing: Text("₹${empList[i].salary}"),
          ),
        ),
      ),
    );
  }
}

// --- 6. SALARY CALCULATION PAGE (Logic Practice) ---
class CalPage extends StatefulWidget {
  const CalPage({super.key});
  @override
  State<CalPage> createState() => _CalPageState();
}

class _CalPageState extends State<CalPage> {
  final search = TextEditingController();
  String res = "Enter Employee ID to calculate";

  void _calculate() {
    // SEARCH Logic: Loop through the global list.
    for (var e in empList) {
      if (e.id == search.text) {
        double b = e.salary;
        double h, t;

        // IF-ELSE Logic: Based on the syllabus requirements.
        if (b > 15000) {
          h = b * 0.12; // HRA 12%
          t = b * 0.14; // TA 14%
        } else if (b >= 8000) {
          h = b * 0.10; // HRA 10%
          t = b * 0.08; // TA 8%
        } else {
          h = b * 0.07; // HRA 7%
          t = b * 0.07; // TA 7%
        }

        double gross = b + h + t;

        // Update the 'res' string inside setState to show the math result.
        setState(() {
          res = "Employee: ${e.name}\nGross Salary: ₹$gross";
        });
        return; // Exit the loop and function once found
      }
    }
    // If loop finishes without finding the ID.
    setState(() {
      res = "Employee ID not found!";
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text("Salary Calculator")),
      body: Padding(
        padding: const EdgeInsets.all(20),
        child: Column(
          children: [
            TextField(
                controller: search,
                decoration: const InputDecoration(labelText: "Search by ID")),
            const SizedBox(height: 10),
            ElevatedButton(
                onPressed: _calculate, child: const Text("Calculate Salary")),
            const SizedBox(height: 30),
            // Text widget displaying the 'res' string.
            Text(res,
                textAlign: TextAlign.center,
                style: const TextStyle(fontSize: 18, fontWeight: FontWeight.bold)),
          ],
        ),
      ),
    );
  }
}
