import 'package:flutter/material.dart';

// void main() is the entry point of the app.
// runApp() starts the Flutter application.
// MaterialApp is the root widget that provides themes and navigation.
void main() => runApp(const MaterialApp(
      home: LoginScreen(), // First screen to show
      debugShowCheckedModeBanner: false, // Removes the red debug tag
    ));

// --- 1. DATA MODEL (Blueprint) ---
// We create a class to define what an 'Employee' object looks like.
class Employee {
  String id, name, des, date;
  double salary;

  // Constructor: Used to create an instance of this class.
  // We use positional parameters (no curly braces) for easier exam writing.
  Employee(this.id, this.name, this.des, this.salary, this.date);
}

// Global List: Stores all employee objects created during the app session.
List<Employee> empList = [];

// --- 2. LOGIN SCREEN (Stateful because it handles user input) ---
class LoginScreen extends StatefulWidget {
  const LoginScreen({super.key}); // super.key passes the widget ID to the parent

  @override
  State<LoginScreen> createState() => _LoginScreenState();
}

class _LoginScreenState extends State<LoginScreen> {
  // TextEditingControllers: Used to 'spy' on and grab text from TextFields.
  final userC = TextEditingController();
  final passC = TextEditingController();

  // Function to validate login logic.
  void login() {
    // Basic if-else validation.
    if (userC.text == "admin" && passC.text == "123") {
      // Navigator.pushReplacement moves to the next screen and REMOVES the login screen from history.
      Navigator.pushReplacement(
          context, MaterialPageRoute(builder: (c) => const HomePage()));
    } else {
      // ScaffoldMessenger shows a small popup (SnackBar) at the bottom.
      ScaffoldMessenger.of(context)
          .showSnackBar(const SnackBar(content: Text("Login Failed")));
    }
  }

  @override
  Widget build(BuildContext context) {
    // Scaffold: The basic layout structure (Appbar + Body).
    return Scaffold(
      appBar: AppBar(title: const Text("Login Screen")),
      body: Padding(
        padding: const EdgeInsets.all(20), // Adds space around the contents
        child: Column(
          children: [
            // TextField: Where the user types information.
            TextField(
                controller: userC,
                decoration: const InputDecoration(labelText: "Username")),
            TextField(
                controller: passC,
                decoration: const InputDecoration(labelText: "Password"),
                obscureText: true), // Hides the password characters
            const SizedBox(height: 20), // Adds vertical space
            ElevatedButton(
                onPressed: login,
                child: const Text("Login")), // Triggers login function
          ],
        ),
      ),
    );
  }
}

